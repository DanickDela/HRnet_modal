{
  "name": "@delaroche/hrnet-modal",
  "version": "1.0.0",
  "description": "Reusable customizable modal component for React",
  "type": "module",
  "main": "./dist/hrnet-modal.umd.cjs",
  "module": "./dist/hrnet-modal.js",
  "exports": {
    ".": {
      "import": "./dist/hrnet-modal.js",
      "require": "./dist/hrnet-modal.umd.cjs"
    },
    "./style.css": "./dist/hrnet-modal.css"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "react",
    "modal",
    "popup",
    "dialog",
    "hrnet"
  ],
  "author": "Danick Delaroche",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanickDela/HRnet_modal.git"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest"
  }
}
