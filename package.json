{
  "name": "@delaroche/hrnet-modal",
  "version": "0.1.0",
  "description": "Reusable customizable modal component for React",
  "main": "dist/hrnet-modal.umd.cjs",
  "module": "dist/hrnet-modal.js",
  "exports": {
    ".": {
      "import": "./dist/hrnet-modal.js",
      "require": "./dist/hrnet-modal.umd.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "react",
    "modal",
    "popup",
    "dialog",
    "hrnet"
  ],
  "author": "Danick Delaroche",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DanickDela/hrnet-modal.git"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "prop-types": "^15.8.1"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "sass-embedded": "^1.99.0",
    "vite": "^8.0.10"
  },
  "bugs": {
    "url": "https://github.com/DanickDela/hrnet-modal/issues"
  },
  "homepage": "https://github.com/DanickDela/hrnet-modal#readme"
